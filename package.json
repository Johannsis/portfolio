{
  "name": "portfolio",
  "version": "0.1.0",
  "private": false,
  "homepage": "https://Johannsis.github.io/portfolio",
  "license": "MIT",
  "author": "Johannes Hoersch <johanneshoersch@gmail.com>",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "bunx serve out",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt . --write",
    "type-check": "tsc --noEmit",
    "bundle:size": "bun scripts/check-bundle-size.mjs",
    "lighthouse:ci": "lhci autorun --config=.lighthouserc.json",
    "release": "semantic-release",
    "prune:node-modules": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "prune:next": "find . -name '.next' -type d -prune -exec rm -rf '{}' +",
    "prune:all": "bun run prune:node-modules && bun run prune:next"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "cssnano": "^7.1.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "postcss": "^8.5.8",
    "semantic-release": "^25.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "6.0.2"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "oxlint --fix"
    ]
  },
  "engines": {
    "bun": "^1.3.10",
    "node": ">=24.0.0"
  },
  "packageManager": "bun@1.3.10"
}
